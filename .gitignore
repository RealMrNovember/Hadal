# Unity
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# IDE
.vs/
.idea/
*.unityproj
*.suo
*.user
*.userprefs
# Ignore generated csproj/sln except shared library (backend + CI)
*.csproj
*.sln
!shared/**/*.csproj
!shared/**/*.sln

# OS
.DS_Store
Thumbs.db

# Addressables
[Aa]ssets/AddressableAssetsData/*/assetlinking.bin
[Aa]ssets/AddressableAssetsData/*/catalog*.json
[Aa]ssets/AddressableAssetsData/*/settings*.asset

# Plastic / Collaborate
*.private
*.private.meta
collabignore.txt

# .NET build output (HADAL.Shared)
shared/**/bin/
shared/**/obj/

# Precompiled plugin copy (Unity uses com.hadal.shared package sources)
Assets/_Hadal/Plugins/Shared/*.dll
Assets/_Hadal/Plugins/Shared/*.dll.meta
